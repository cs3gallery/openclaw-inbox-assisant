NODE_ENV=development
APP_NAME=openclaw-inbox-assistant
LOG_LEVEL=info

APP_HOST=0.0.0.0
APP_PORT=3000
HOST_APP_PORT=3400
WORKER_HOST=0.0.0.0
WORKER_PORT=3001
HOST_WORKER_PORT=3401
WORKER_HEARTBEAT_INTERVAL_MS=30000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=openclaw_inbox
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=change-me
POSTGRES_MAX_CONNECTIONS=10
POSTGRES_CONNECT_TIMEOUT_MS=10000
DATABASE_SSL_ENABLED=false
DATABASE_URL=postgresql://openclaw:change-me@postgres:5432/openclaw_inbox

REDIS_URL=redis://redis:6379
REDIS_CONNECT_TIMEOUT_MS=10000

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
EMBEDDING_VECTOR_SIZE=1536
QDRANT_COLLECTION_DISTANCE=Cosine
QDRANT_COLLECTION_ON_DISK_PAYLOAD=true

STARTUP_MAX_ATTEMPTS=8
STARTUP_INITIAL_BACKOFF_MS=1000
STARTUP_MAX_BACKOFF_MS=10000
SHUTDOWN_TIMEOUT_MS=10000

OPENCLAW_MSGRAPH_BASE_URL=http://host.docker.internal:3000
OPENCLAW_MSGRAPH_SHARED_SECRET=replace-me
OPENCLAW_MSGRAPH_CONNECTION_NAME=
OPENCLAW_MSGRAPH_AUTH_MODE=delegated
MAIL_INGESTION_FOLDERS=Inbox
MAIL_INGESTION_PAGE_SIZE=100
MAIL_INGESTION_POLL_WINDOW_MINUTES=1440
MAIL_INGESTION_FALLBACK_LOOKBACK_MINUTES=240
MAIL_INGESTION_STATUS_LIMIT=20

ADMINER_PORT=8080
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
