{
  "name": "openclaw-inbox-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready inbox organizer and executive assistant service scaffold for OpenClaw.",
  "main": "dist/app.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev:app": "tsx watch src/app.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:telegram-bridge": "tsx watch src/telegramBridge.ts",
    "start:app": "node dist/app.js",
    "start:worker": "node dist/worker.js",
    "start:telegram-bridge": "node dist/telegramBridge.js",
    "migrate": "tsx src/db/postgres/migrator.ts",
    "bootstrap:qdrant": "tsx src/db/qdrant/bootstrap.ts",
    "verify:health": "npm run build && node dist/scripts/verifyHealth.js",
    "verify:infra": "docker compose exec -T app node dist/scripts/verifyInfra.js",
    "verify:infra:local": "npm run build && node dist/scripts/verifyInfra.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.17.0",
    "dotenv": "^16.4.7",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.2",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
